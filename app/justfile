# Joy App -- Tauri + SolidJS

mod tauri 'src-tauri/justfile'

# List recipes
default:
    @just --list

# Set version (package.json + Tauri)
version semver:
    sed -i 's/"version": ".*"/"version": "{{semver}}"/' package.json
    just tauri version {{semver}}
    @echo "  app/package.json -> {{semver}}"

# Check tools
doctor:
    @echo "=== App ==="
    @command -v node >/dev/null && echo "  node: $(node --version)" || echo "  node: MISSING"
    @command -v yarn >/dev/null && echo "  yarn: $(yarn --version)" || echo "  yarn: MISSING"
    @test -d node_modules && echo "  node_modules: ok" || echo "  node_modules: MISSING (run just app install)"

# Start Tauri dev server
dev:
    yarn tauri dev

# Production build
build:
    yarn tauri build

# Install Node deps
install:
    yarn install

# Run tests
test:
    yarn test

# Format (Prettier)
fmt:
    yarn prettier --write .

# Check formatting
fmt-check:
    yarn prettier --check .

# Lint (ESLint)
lint:
    yarn eslint .
